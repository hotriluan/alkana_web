# Alkana Web — Environment Variables Example
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# WordPress DB (local dev)
DB_HOST=localhost
DB_NAME=alkana_local
DB_USER=root
DB_PASSWORD=

# WordPress table prefix
DB_PREFIX=wp_

# Site URLs
WP_HOME=http://localhost:8888
WP_SITEURL=http://localhost:8888

# Staging
STAGING_HOST=staging.alkana.vn
STAGING_FTP_USER=
STAGING_FTP_PASS=

# Mat Bao cPanel SSH
MATBAO_SSH_HOST=
MATBAO_SSH_USER=
MATBAO_SSH_PORT=22
