# BEGIN WordPress
# ── Auto-generated by WordPress — do not remove this marker ──────────────────
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# ─────────────────────────────────────────────────────────────────────────────
# ALKANA 301 Redirect Rules (OLD alkana.vn → NEW alkana.vn)
# Applied BEFORE WordPress routing to ensure proper 301 responses.
# Review with Screaming Frog before go-live.
# ─────────────────────────────────────────────────────────────────────────────

# Canonical: force www → non-www (adjust if site uses www)
# RewriteCond %{HTTP_HOST} ^www\.alkana\.vn [NC]
# RewriteRule ^(.*)$ https://alkana.vn/$1 [R=301,L]

# ── Static page redirects ─────────────────────────────────────────────────────
RewriteRule ^lien-he/?$         /contact/       [R=301,L,NE]
RewriteRule ^gioi-thieu/?$      /about/         [R=301,L,NE]
RewriteRule ^giai-phap/?$       /solutions/     [R=301,L,NE]
RewriteRule ^tai-nguyen/?$      /resources/     [R=301,L,NE]
RewriteRule ^tuyen-dung/?$      /careers/       [R=301,L,NE]
RewriteRule ^tin-tuc/?$         /news/          [R=301,L,NE]
RewriteRule ^cong-trinh/?$      /projects/      [R=301,L,NE]
RewriteRule ^san-pham/?$        /products/      [R=301,L,NE]

# ── News articles: /tin-tuc/{slug}/ → /news/{slug}/ ──────────────────────────
RewriteRule ^tin-tuc/([^/]+)/?$         /news/$1/               [R=301,L,NE]

# ── Project posts: /cong-trinh/{slug}/ → /projects/{slug}/ ──────────────────
RewriteRule ^cong-trinh/([^/]+)/?$      /projects/$1/           [R=301,L,NE]

# ── Product category archives: /san-pham/{category}/ → /product-category/{category}/ ──
RewriteRule ^san-pham/([^/]+)/?$        /product-category/$1/   [R=301,L,NE]

# ── Product detail pages: /san-pham/{category}/{slug}/ → /products/{slug}/ ───
RewriteRule ^san-pham/[^/]+/([^/]+)/?$  /products/$1/           [R=301,L,NE]

# ─────────────────────────────────────────────────────────────────────────────
# WordPress default routing (keep below all custom rules)
# ─────────────────────────────────────────────────────────────────────────────
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options   "nosniff"
    Header always set X-Frame-Options          "SAMEORIGIN"
    Header always set Referrer-Policy          "strict-origin-when-cross-origin"
    Header always set Permissions-Policy       "camera=(), microphone=(), geolocation=()"
    # CSP: tighten after go-live once you know all asset origins
    # Header always set Content-Security-Policy "default-src 'self' ..."
</IfModule>

# ── Block access to sensitive files ──────────────────────────────────────────
<FilesMatch "^(wp-config\.php|\.env|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# ── Disable directory listing ─────────────────────────────────────────────────
Options -Indexes

# ── LiteSpeed Cache hint (works with LSCache plugin) ─────────────────────────
# <IfModule LiteSpeed>
#     CacheLookup public on
# </IfModule>
